import yfinance as _y,numpy as _n,pandas as _p,sys as _s,calendar as _c
from scipy.optimize import least_squares as _l
import matplotlib.pyplot as _m
_V,_E,_L,_D1,_D2=1,1e-2,.15,.25,.25
class _SE:
 def __init__(O):O.h=[];O.I()
 def I(O):
  print("="*50+"\n💎 Sovereign Engine: Blackbox Mode\n"+"="*50)
  O.y,O.m=int(input("📅 Year: ")),int(input("📅 Month: "))
  O.v,O.t=float(input("💰 Initial Rsv: ")),float(input("🎯 Target Rsv: "))
  O.e,O.f=float(input("🚢 Export: "))/30.0,float(input("🏦 Fixed: "))/30.0
  O.w,O.P,O.Q=float(input("⚙️ w: ")),float(input("⚙️ P: ")),float(input("⚙️ Q: "))
 def K(O,t,p,d):return _n.exp(-abs((t.hour+t.minute/60.0)-p))*_n.exp(-abs(t.weekday()-d))
 def M(O,v,e,d,t,P,Q,w):
  C,a,k,x=v;R=[]
  for i in range(5):
   T=t[i];W=_n.exp(-_L*abs((T.hour+T.minute/60.0)-22.0))
   M=_V*W*(1.0/((C-e[i])**2+_E))*Q
   R.append(x-(_D1*(1.0-w)*O.K(T,10.0,0.0)*O.e-_D2*O.f*O.K(T,14.0,4.0)-(((1.0-a)*M)+(a*(abs(d[i])/k)*_V*P))))
  return R
 def F(O):
  _,L=_c.monthrange(O.y,O.m);d=_y.download("USDKRW=X",start=f"{O.y}-{O.m:02d}-01",end=f"{O.y}-{O.m:02d}-{L}",interval="15m",progress=False)
  d['Close']=d['Close'].ffill().rolling(window=5,min_periods=1).mean()
  if isinstance(d.columns,_p.MultiIndex):d.columns=d.columns.get_level_values(0)
  return d
 def R(O):
  O.d=O.F();O.fv=O.v;P=O.d['Close'].values;T=O.d.index
  dE=_n.diff(P,prepend=P[0]);dt=_n.insert(_n.diff(T).astype('timedelta64[m]').astype(int),0,1)
  for i in range(4,len(O.d)):
   ew,dw,tw=P[i-4:i+1],dE[i-4:i+1],T[i-4:i+1];em=_n.max(ew)
   try:
    X=_l(O.M,x0=[em+25,.5,.5,0],bounds=([em+.01,0,.01,-250],[2500,1,30,250]),args=(ew,dw,tw,O.P,O.Q,O.w)).x
    O.fv+=(X[3]*dt[i])/15.0
   except:pass
   if i%10==0:O.h.append({'Time':T[i],'V':O.fv});_s.stdout.write(f'\r⚡ Processing: {O.fv:.4f}B')
  O.P_()
 def P_(O):
  H=_p.DataFrame(O.h);_m.style.use('dark_background');_m.figure(figsize=(12,6))
  _m.plot(H['Time'],H['V'],color='#00FFCC',lw=2);_m.title("Sovereign Engine | Blackbox Mode");_m.grid(True,alpha=0.2);_m.show()
if __name__=="__main__":_SE().R()
